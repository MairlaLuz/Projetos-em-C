#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct No {

    char item[30];
    struct No *proximo;
};

struct No *inicio = NULL;

void inserirItem() {

    struct No *novo;

    novo = malloc(sizeof(struct No));

    printf("Digite o item: ");
    scanf(" %29[^\n]", novo->item);

    novo->proximo = inicio;

    inicio = novo;

    printf("Item inserido!\n");
}

void listarItens() {

    struct No *atual = inicio;

    printf("\nItens da mochila:\n");

    while (atual != NULL) {

        printf("- %s\n", atual->item);

        atual = atual->proximo;
    }
}

void buscarItem() {

    char nome[30];

    printf("Digite o item: ");
    scanf(" %29[^\n]", nome);

    struct No *atual = inicio;

    while (atual != NULL) {

        if (strcmp(atual->item, nome) == 0) {

            printf("Item encontrado!\n");
            return;
        }

        atual = atual->proximo;
    }

    printf("Item não encontrado!\n");
}

void removerItem() {

    char nome[30];

    printf("Digite o item para remover: ");
    scanf(" %29[^\n]", nome);

    struct No *atual = inicio;
    struct No *anterior = NULL;

    while (atual != NULL &&
           strcmp(atual->item, nome) != 0) {

        anterior = atual;
        atual = atual->proximo;
    }

    if (atual == NULL) {

        printf("Item não encontrado!\n");
        return;
    }

    if (anterior == NULL) {

        inicio = atual->proximo;

    } else {

        anterior->proximo = atual->proximo;
    }

    free(atual);

    printf("Item removido!\n");
}

int main() {

    int opcao;

    do {

        printf("\n1 - Inserir\n");
        printf("2 - Remover\n");
        printf("3 - Listar\n");
        printf("4 - Buscar\n");
        printf("0 - Sair\n");

        printf("Escolha: ");
        scanf("%d", &opcao);

        getchar();

        switch(opcao) {

            case 1:
                inserirItem();
                break;

            case 2:
                removerItem();
                break;

            case 3:
                listarItens();
                break;

            case 4:
                buscarItem();
                break;

            case 0:
                printf("Saindo...\n");
                break;

            default:
                printf("Opção inválida!\n");
        }

    } while(opcao != 0);

    return 0;
}
