#include <xc.h>
#include <stdio.h>
#define _XTAL_FREQ 8000000

// CONFIG
#pragma config FOSC = HS
#pragma config WDT = OFF
#pragma config LVP = OFF
#pragma config PBADEN = OFF

// -------- LCD --------
#define RS LATDbits.LATD0
#define EN LATDbits.LATD1
#define D4 LATDbits.LATD2
#define D5 LATDbits.LATD3
#define D6 LATDbits.LATD4
#define D7 LATDbits.LATD5

void pulseEnable() {
    EN = 1; __delay_us(2); EN = 0;
}

void send4bits(unsigned char data) {
    D4 = (data>>0)&1;
    D5 = (data>>1)&1;
    D6 = (data>>2)&1;
    D7 = (data>>3)&1;
    pulseEnable();
}

void lcd_cmd(unsigned char cmd) {
    RS = 0;
    send4bits(cmd>>4);
    send4bits(cmd&0x0F);
    __delay_ms(2);
}

void lcd_data(unsigned char data) {
    RS = 1;
    send4bits(data>>4);
    send4bits(data&0x0F);
    __delay_ms(2);
}

void lcd_init() {
    __delay_ms(20);
    lcd_cmd(0x02);
    lcd_cmd(0x28);
    lcd_cmd(0x0C);
    lcd_cmd(0x06);
    lcd_cmd(0x01);
}

void lcd_string(const char *str) {
    while(*str) lcd_data(*str++);
}

// -------- ADC (Solo) --------
void ADC_Init() {
    ADCON1 = 0x0E;
    ADCON2 = 0xA9;
}

int ADC_Read(int ch) {
    ADCON0 = (ch<<2);
    __delay_ms(2);
    GO_nDONE = 1;
    while(GO_nDONE);
    return ((ADRESH<<8)+ADRESL);
}

// -------- DHT22 --------
#define DHT_TRIS TRISAbits.TRISA0
#define DHT_PORT PORTAbits.RA0
#define DHT_LAT LATAbits.LATA0

void DHT_Start() {
    DHT_TRIS = 0;
    DHT_LAT = 0;
    __delay_ms(20);
    DHT_LAT = 1;
    __delay_us(30);
    DHT_TRIS = 1;
}

unsigned char DHT_Check() {
    __delay_us(40);
    if(!DHT_PORT) {
        __delay_us(80);
        if(DHT_PORT) return 1;
    }
    return 0;
}

unsigned char DHT_Read() {
    unsigned char i, data = 0;
    for(i=0;i<8;i++) {
        while(!DHT_PORT);
        __delay_us(30);
        if(DHT_PORT)
            data = (data<<1)|1;
        else
            data = (data<<1);
        while(DHT_PORT);
    }
    return data;
}

// -------- RELÉ --------
#define RELAY LATBbits.LATB0

// -------- MAIN --------
void main() {

    TRISD = 0x00; // LCD
    TRISBbits.TRISB0 = 0; // relé
    TRISAbits.TRISA0 = 1; // DHT
    TRISAbits.TRISA1 = 1; // solo

    ADC_Init();
    lcd_init();

    int solo;
    unsigned char temp, hum;

    while(1) {

        // 🌱 Leitura solo
        solo = ADC_Read(1);

        // 🌡️ Leitura DHT22
        DHT_Start();
        if(DHT_Check()) {
            hum = DHT_Read();
            DHT_Read(); // decimal ignorado
            temp = DHT_Read();
            DHT_Read(); // decimal ignorado
            DHT_Read(); // checksum
        }

        // 💧 Lógica irrigação
        if(solo < 300) {
            RELAY = 1;
        } else {
            RELAY = 0;
        }

        // 📺 LCD
        char linha1[16];
        char linha2[16];

        sprintf(linha1, "Temp:%dC", temp);

        if(solo < 300)
            sprintf(linha2, "Solo: SECO");
        else
            sprintf(linha2, "Solo: OK");

        lcd_cmd(0x80);
        lcd_string(linha1);

        lcd_cmd(0xC0);
        lcd_string(linha2);

        __delay_ms(2000);
        lcd_cmd(0x01);
    }
}
