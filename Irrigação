#include <xc.h>
#include <stdio.h>
#define _XTAL_FREQ 8000000

// CONFIG (ajuste se necessário)
#pragma config FOSC = HS
#pragma config WDT = OFF
#pragma config LVP = OFF
#pragma config PBADEN = OFF

// DEFINIÇÕES
#define RELAY LATBbits.LATB0

// DHT22
#define DHT_TRIS TRISAbits.TRISA0
#define DHT_PORT PORTAbits.RA0
#define DHT_LAT LATAbits.LATA0

// FUNÇÃO ADC
void ADC_Init() {
    ADCON1 = 0x0E; // AN0 analógico
    ADCON2 = 0xA9;
}

int ADC_Read(int channel) {
    ADCON0 = (channel<<2);
    __delay_ms(2);
    GO_nDONE = 1;
    while(GO_nDONE);
    return ((ADRESH<<8)+ADRESL);
}

// -------- DHT22 --------
void DHT_Start() {
    DHT_TRIS = 0;
    DHT_LAT = 0;
    __delay_ms(20);
    DHT_LAT = 1;
    __delay_us(30);
    DHT_TRIS = 1;
}

unsigned char DHT_Check() {
    __delay_us(40);
    if(!DHT_PORT) {
        __delay_us(80);
        if(DHT_PORT) return 1;
    }
    return 0;
}

unsigned char DHT_Read() {
    unsigned char i, data = 0;
    for(i=0;i<8;i++) {
        while(!DHT_PORT);
        __delay_us(30);
        if(DHT_PORT)
            data = (data<<1)|1;
        else
            data = (data<<1);
        while(DHT_PORT);
    }
    return data;
}
// -----------------------

void main() {

    TRISBbits.TRISB0 = 0; // relé saída
    TRISAbits.TRISA0 = 1; // DHT
    TRISAbits.TRISA1 = 1; // AN1 solo

    ADC_Init();

    int solo;
    unsigned char temp_int, temp_dec, hum_int, hum_dec, checksum;

    while(1) {

        // 📊 Leitura do solo
        solo = ADC_Read(1); // AN1

        // 🌡️ Leitura DHT22
        DHT_Start();
        if(DHT_Check()) {
            hum_int = DHT_Read();
            hum_dec = DHT_Read();
            temp_int = DHT_Read();
            temp_dec = DHT_Read();
            checksum = DHT_Read();
        }

        // 💧 LÓGICA DE IRRIGAÇÃO
        if(solo < 300) { // solo seco
            RELAY = 1; // liga bomba
        } else {
            RELAY = 0; // desliga bomba
        }

        __delay_ms(2000);
    }
}
